# 复制为 .env 后按需修改
DATABASE_URL=postgresql+asyncpg://superz:superz@localhost:5432/superz
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=43200

# 高德 Web 服务 Key(不配则 POI 搜索返回演示数据)
AMAP_WEB_KEY=

# ===== 微信支付 V3(不配则 /pay/wechat 返回 503,客户端自动走模拟支付)=====
WXPAY_APP_ID=
WXPAY_MCHID=
WXPAY_API_V3_KEY=
WXPAY_CERT_SERIAL_NO=
WXPAY_PRIVATE_KEY_PATH=certs/apiclient_key.pem
WXPAY_NOTIFY_URL=https://你的域名/payments/wechat/notify

# ===== 极光推送(不配则跳过离线推送,WebSocket 前台通道不受影响)=====
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# ===== 阿里云短信(不配则验证码走开发模式:直接返回给客户端)=====
# AccessKey 建议用只授「短信发送」权限的 RAM 子账号
SMS_SECRET_ID=            # 阿里云 AccessKey ID
SMS_SECRET_KEY=           # 阿里云 AccessKey Secret(机密,勿入库)
SMS_SIGN_NAME=爱卡斯科技   # 已审核的短信签名
SMS_TEMPLATE_ID=SMS_510415101   # 短信模板 CODE
SMS_TEMPLATE_PARAM=code   # 模板里验证码变量名(${code} 则填 code)
SMS_REGION_ID=cn-hangzhou

# ===== 公开经营大屏(/screen)=====
# 演示模式:真实数据上叠加模拟增量,页面明示"演示数据"角标;生产保持 0
SCREEN_DEMO=0
